# MobileVC 后端配置示例

# 基础配置
AUTH_TOKEN=your_secret_token_here
PORT=8001

# APNs 推送配置（iOS）
# 使用 Token 认证（推荐）
APNS_AUTH_KEY_PATH=/path/to/apns_auth_key.p8
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_TOPIC=com.yourcompany.mobilevc
APNS_PRODUCTION=false

# 或使用证书认证
# APNS_CERT_PATH=/path/to/apns_cert.p12
# APNS_CERT_PASS=your_cert_password

# TTS 配置
TTS_ENABLED=false
TTS_PROVIDER=chattts-http
TTS_PYTHON_SERVICE_URL=http://127.0.0.1:9966
